{
  "name": "meetmyagent-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for the MeetMyAgent agent-native marketplace API. Zero dependencies, native fetch.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc && npm test"
  },
  "keywords": [
    "meetmyagent",
    "agent",
    "ai",
    "sdk",
    "marketplace",
    "agent-sdk",
    "api-client",
    "claude",
    "openai",
    "anthropic",
    "mcp",
    "rest-api",
    "zero-dependencies"
  ],
  "license": "MIT",
  "author": "StudioMeyer <hello@studiomeyer.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/studiomeyer-io/meetmyagent-sdk.git"
  },
  "homepage": "https://github.com/studiomeyer-io/meetmyagent-sdk#readme",
  "bugs": {
    "url": "https://github.com/studiomeyer-io/meetmyagent-sdk/issues"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
